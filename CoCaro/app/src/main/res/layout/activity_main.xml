<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:translationX="15dp">

        <TableRow android:layout_gravity="center">
            <Button android:id="@+id/bt1" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
            <Button android:id="@+id/bt2" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
            <Button android:id="@+id/bt3" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
        </TableRow>

        <TableRow android:layout_gravity="center">
            <Button android:id="@+id/bt4" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
            <Button android:id="@+id/bt5" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
            <Button android:id="@+id/bt6" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
        </TableRow>

        <TableRow android:layout_gravity="center">
            <Button android:id="@+id/bt7" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
            <Button android:id="@+id/bt8" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
            <Button android:id="@+id/bt9" android:layout_width="50pt" android:layout_height="50pt" android:layout_margin="3pt" android:textSize="50dp" android:onClick="btClick" app:backgroundTint="#BCB9B9" android:padding="0dp"/>
        </TableRow>

        <TableRow android:gravity="center" android:layout_margin="5pt">
            <Button
                android:id="@+id/btPlayAgain"
                android:text="Bắt đầu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </TableRow>

        <TableRow android:gravity="center" android:layout_margin="5pt">
            <TextView
                android:id="@+id/txtShowresult"
                android:layout_span="3"
                android:layout_width="match_parent"
                android:gravity="center"
                android:textSize="30sp"
                android:text="Result"
                android:textColor="#000000"
                android:visibility="invisible"
                android:layout_height="wrap_content"/>
        </TableRow>

    </TableLayout>

</androidx.constraintlayout.widget.ConstraintLayout>